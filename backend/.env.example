# =============================================================================
# .env.example  —  Plantilla de variables de entorno del backend
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este fichero como .env  (cp .env.example .env)
#   2. Rellena los valores marcados con <RELLENAR>
#   3. NUNCA subas .env al repositorio (ya esta en .gitignore)
# =============================================================================

# --- Aplicacion ---
APP_NAME="TFG LLM Benchmarking API"
APP_VERSION="0.1.0"
API_PREFIX="/api/v1"
ENVIRONMENT="development"
DEBUG=false

# --- CORS ---
# En desarrollo el frontend Vite corre en el puerto 5173
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Base de datos PostgreSQL ---
# Cuando usas docker-compose, los valores por defecto funcionan directamente
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/tfg_llm_db"
POSTGRES_DB=tfg_llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# --- pgAdmin (docker-compose) ---
PGADMIN_EMAIL=admin@tfg.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# --- JWT ---
# Genera un valor aleatorio seguro con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<RELLENAR_CON_VALOR_ALEATORIO_32_BYTES_HEX>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# CLAVES DE API DE LOS PROVEEDORES LLM
# Todas son opcionales: la app arranca aunque alguna no este configurada.
# El proveedor sin clave devolvera tuvo_error=True en el benchmark.
# =============================================================================

# --- Anthropic Claude 3.5 Sonnet ---
# Consola: https://console.anthropic.com/settings/keys
# Formato:  sk-ant-api03-...
ANTHROPIC_API_KEY=<RELLENAR>

# --- OpenAI GPT-4o + DALL-E 3 ---
# Consola:  https://platform.openai.com/api-keys
# Formato:  sk-proj-... (cuentas nuevas) o sk-... (cuentas antiguas)
OPENAI_API_KEY=<RELLENAR>

# --- Google AI Gemini 2.0 Flash + Imagen 3 ---
# Consola:  https://aistudio.google.com/app/apikey
# Formato:  AIza...
GOOGLE_API_KEY=<RELLENAR>

# --- xAI Grok 2 + Aurora (imagen) ---
# Consola:  https://console.x.ai/
# Formato:  xai-...
XAI_API_KEY=<RELLENAR>
