# ============================================================
# .env.example
# Path: .env.example (raiz del proyecto — plantilla en git)
#
# Descripcion:
#   Plantilla de todas las variables de entorno del proyecto.
#   Copia este fichero a backend/.env y rellena los valores reales.
#   El fichero backend/.env esta en .gitignore y NUNCA se sube al repo.
#
#   Uso:
#     copy .env.example backend\.env    (Windows)
#     cp .env.example backend/.env      (Linux/Mac)
#
# Sprint: Sprint 1
# ============================================================


# -------------------------------------------------------
# PostgreSQL (leido por docker-compose.yml)
# -------------------------------------------------------
POSTGRES_DB=tfg_llm_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# -------------------------------------------------------
# pgAdmin (interfaz web para gestionar la base de datos)
# Acceso: http://localhost:5050
# -------------------------------------------------------
PGADMIN_EMAIL=admin@tfg.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050


# -------------------------------------------------------
# Backend: conexion a base de datos
# Formato: postgresql+asyncpg://usuario:password@host:puerto/nombre_db
# -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@localhost:5432/tfg_llm_db


# -------------------------------------------------------
# Backend: entorno y modo debug
# ENVIRONMENT: development | staging | production
# DEBUG: true solo en development
# -------------------------------------------------------
ENVIRONMENT=development
DEBUG=true


# -------------------------------------------------------
# Backend: CORS
# Lista separada por comas de origenes permitidos.
# En desarrollo: http://localhost:5173 (Vite dev server)
# -------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:5173"]


# -------------------------------------------------------
# Backend: autenticacion JWT
# Generar SECRET_KEY con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# -------------------------------------------------------
SECRET_KEY=change_me_generate_with_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


# -------------------------------------------------------
# LLM: Anthropic Claude
# Obtener en: console.anthropic.com
# -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx


# -------------------------------------------------------
# LLM: OpenAI (ChatGPT)
# Obtener en: platform.openai.com/api-keys
# -------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxx


# -------------------------------------------------------
# LLM: Google Gemini 2.0 Flash + Imagen 3
# Obtener en: aistudio.google.com/app/apikey
# -------------------------------------------------------
GOOGLE_API_KEY=AIzaSy-xxxxx


# -------------------------------------------------------
# LLM: xAI Grok 2 + Aurora (imagen)
# Obtener en: console.x.ai
# -------------------------------------------------------
XAI_API_KEY=xai-xxxxx


# -------------------------------------------------------
# Admin inicial del estudio (creado con scripts/seed_admin.py)
# -------------------------------------------------------
ADMIN_EMAIL=admin@tfg.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
