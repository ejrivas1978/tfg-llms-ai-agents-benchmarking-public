@startuml cls_capas_arquitectura

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' Inyectado por docs/diagramas/plantuml/_normalizar_estilo_claro.py
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

' Notas: amarillo palido, texto negro, borde naranja oscuro.
skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

' Titulos
skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

' Divisores y headers
skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

' ─── Secuencia ───────────────────────────
skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ─── Actividad ───────────────────────────
skinparam activity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  StartColor #000000
  EndColor #000000
  DiamondBackgroundColor #DAE8FC
  DiamondBorderColor #000000
  DiamondFontColor #000000
}
skinparam activityArrowColor #000000

' ─── Estados ─────────────────────────────
skinparam state {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
  ArrowColor #000000
  StartColor #000000
  EndColor #000000
}

' ─── Casos de uso ────────────────────────
skinparam usecase {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam actor {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
}

' ─── Clases ──────────────────────────────
skinparam class {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  AttributeFontColor #000000
  StereotypeFontColor #595959
}
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #FFF2CC
skinparam classBorderColor #000000

' ─── Componentes / paquetes ──────────────
skinparam component {
  BackgroundColor #D5E8D4
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F2F2F2
  BorderColor #000000
  FontColor #000000
}
skinparam node {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #E1D5E7
  BorderColor #000000
  FontColor #000000
}

' ─── ER ──────────────────────────────────
skinparam entity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ============================================================
' Clases: Capas backend - repositories + services + LLM engine
' Ruta: docs/diagramas/plantuml/cls_capas_arquitectura.puml
'
' Vista de las tres capas no-modelo del backend:
'   - Repositories: acceso a datos (patron Repository).
'   - Services: logica de negocio.
'   - LLM engine: clientes asincronos + runner paralelo.
'
' Los modelos ORM puros estan en cls_modelos_orm.
' ============================================================

' ─── Repositories ───────────────────────────────
package "app.repositories" {
  class BenchmarkEvaluacionRepository {
    + crear(peticion) : BenchmarkEvaluacion
    + obtener_por_id(id) : BenchmarkEvaluacion?
    + actualizar_estado(id, status, jaccard?) : void
    + listar(filtros) : list[BenchmarkEvaluacion]
    + listar_para_export(filtros) : list[BenchmarkEvaluacion]
    + contar_evaluaciones() : int
    + contar_evaluaciones_imagen_generativa() : int
    + evaluaciones_por_categoria() : list[tuple]
    + evaluaciones_por_semana() : list[tuple]
  }
  class LLMResponseRepository {
    + crear_desde_resultado(resultado) : LLMResponse
    + medias_por_proveedor() : list[tuple]
    + medias_imagen_por_proveedor() : list[tuple]
    + textos_por_evaluacion_y_proveedor() : dict
  }
  class UserEvaluationRepository {
    + crear(eval) : UserEvaluation
    + ratings_por_proveedor() : list[tuple]
    + ranking_medio_por_proveedor() : list[tuple]
    + ratings_por_proveedor_y_categoria() : list[tuple]
    + tasa_rechazo_por_proveedor() : list[tuple]
    + ratings_generacion_imagen_por_proveedor() : list[tuple]
  }
  class UsuarioAppRepository {
    + obtener_por_nick(nick) : UsuarioApp?
    + obtener_por_id(id) : UsuarioApp?
    + listar(filtros) : list[UsuarioApp]
    + crear(nick, password_hash) : UsuarioApp
    + actualizar(usuario) : UsuarioApp
    + contar_admins() : int
  }
}

' ─── Services ────────────────────────────────────
package "app.services" {
  class BenchmarkService {
    + ejecutar(peticion, actor) : ResultadoBenchmark
    - _es_rechazo_politica(resultado) : bool
    - _CENSURA_KW : tuple[str]
  }
  class EvaluacionService {
    + crear(peticion) : UserEvaluation
    + listar_por_evaluacion(id) : list[UserEvaluation]
  }
  class StatsService {
    + obtener() : RespuestaStats
    - _construir_metricas_modelo() : list
    - _construir_jaccard() : list
    - _construir_heatmap() : list
    - _construir_tasa_rechazo() : list
  }
  class UsuarioAppAdminService {
    + conceder_acceso(id, cuota) : UsuarioApp
    + ampliar_tokens(id, cantidad) : UsuarioApp
    + resetear_evaluaciones(id, cuota) : void
    + promover_admin(caller, id, email) : UsuarioApp
    + degradar_admin(caller, id) : UsuarioApp
    + eliminar_usuario(caller, id) : void
  }
  class UsuarioAppAuthService {
    + registrar(nick, password) : UsuarioApp
    + login(nick, password) : RespuestaTokenUsuarioApp
  }
  class AuthService {
    + login(nick, password) : RespuestaToken
    + obtener_por_id(id) : UsuarioApp
  }
}

' ─── LLM Engine ──────────────────────────────────
package "app.llm_engine" {
  abstract class BaseLLMClient {
    + {abstract} call(prompt, subcat?, img?) : ResultadoLLM
  }
  class AnthropicClient
  class OpenAIClient
  class GeminiClient
  class GrokClient

  class LLMRunner {
    + ejecutar_todos(prompt, subcat?, img?) : list[ResultadoLLM]
  }
  class MetricsCalculator {
    + calcular(text, tokens, latency, categoria) : Metricas
  }
}

' ─── Relaciones ──────────────────────────────────
BenchmarkService ..> BenchmarkEvaluacionRepository
BenchmarkService ..> LLMResponseRepository
BenchmarkService ..> UsuarioAppRepository
BenchmarkService ..> LLMRunner

EvaluacionService ..> UserEvaluationRepository
EvaluacionService ..> LLMResponseRepository

StatsService ..> BenchmarkEvaluacionRepository
StatsService ..> LLMResponseRepository
StatsService ..> UserEvaluationRepository

UsuarioAppAdminService ..> UsuarioAppRepository
UsuarioAppAuthService ..> UsuarioAppRepository
AuthService ..> UsuarioAppRepository

LLMRunner ..> BaseLLMClient : asyncio.gather
LLMRunner ..> MetricsCalculator
BaseLLMClient <|-- AnthropicClient
BaseLLMClient <|-- OpenAIClient
BaseLLMClient <|-- GeminiClient
BaseLLMClient <|-- GrokClient

@enduml
