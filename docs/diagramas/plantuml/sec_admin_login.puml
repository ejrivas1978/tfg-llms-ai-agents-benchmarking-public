' ============================================================
' Secuencia: Login del administrador (RF-16)
' Ruta: docs/diagramas/plantuml/sec_admin_login.puml
'
' Tras la unificacion ADR-027 admin y usuario web comparten la
' tabla usuarios_app. El login admin (endpoint POST /auth/login)
' acepta nick+password, exige is_admin=True y emite un JWT que
' incluye el flag es_root para que el frontend active u oculte
' los botones de gestion de roles sin un round-trip extra.
'
' Cubre 4 ramas: nick inexistente, password incorrecta,
' is_admin=False (usuario regular intentando login admin), OK.
' Para no filtrar la existencia del nick, todas las ramas de
' error devuelven el mismo mensaje generico ("Credenciales
' incorrectas").
' ============================================================

actor "Administrador" as AD
participant "NickPage\n(React)" as NP
participant "authApi\n(axios)" as API
participant "POST /auth/login\n(FastAPI)" as LOGIN
participant "AuthService" as SVC
participant "UsuarioAppRepository" as REPO
participant "Security" as SEC
database "PostgreSQL\nusuarios_app" as DB

note over AD,NP : si el nick literal es "admin"\nse abre directamente la vista login_admin

AD -> NP  : nick + contrasena
activate NP
NP -> API : loginAdmin({ nick, password })
activate API
API -> LOGIN : POST /api/v1/auth/login
activate LOGIN
LOGIN -> SVC : login(nick, password)
activate SVC
note right of SVC
  PeticionLogin (Pydantic) aplica
  field_validator: nick.strip().lower()
  case-insensitive.
end note
SVC -> REPO : obtener_por_nick(nick)
activate REPO
REPO -> DB : SELECT FROM usuarios_app WHERE nick = ?
DB --> REPO : UsuarioApp | None
REPO --> SVC : usuario | None
deactivate REPO

alt nick no existe
  SVC --> LOGIN : HTTPException 401\n"Credenciales incorrectas"
else password incorrecta
  SVC -> SEC : verify_password(plain, hash)
  SEC --> SVC : False
  SVC --> LOGIN : HTTPException 401\n"Credenciales incorrectas"
else is_admin == False (usuario regular)
  SVC -> SVC : usuario.is_admin == False
  SVC --> LOGIN : HTTPException 401\n"Credenciales incorrectas"
  note right of SVC
    mismo mensaje generico:
    no filtramos la existencia
    del nick desde este endpoint
  end note
else OK (es admin con password valida)
  SVC -> SEC : create_access_token({ "sub": usuario.id })
  SEC --> SVC : access_token
  SVC --> LOGIN : RespuestaToken(\n  access_token,\n  expires_in,\n  es_root=usuario.es_root\n)
  LOGIN --> API : HTTP 200 { access_token, es_root }
  API --> NP : token + es_root
  NP -> NP : adminStore.setSession(token, esRoot)\nnickStore.setNick(nick)
  NP --> AD : continua con post-login\n(ver sec_admin_post_login)
end
deactivate SVC
deactivate LOGIN
deactivate API
deactivate NP

@enduml
