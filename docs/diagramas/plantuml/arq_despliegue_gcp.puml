@startuml arq_despliegue_gcp

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' Inyectado por docs/diagramas/plantuml/_normalizar_estilo_claro.py
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

' Notas: amarillo palido, texto negro, borde naranja oscuro.
skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

' Titulos
skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

' Divisores y headers
skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

' ─── Secuencia ───────────────────────────
skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ─── Actividad ───────────────────────────
skinparam activity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  StartColor #000000
  EndColor #000000
  DiamondBackgroundColor #DAE8FC
  DiamondBorderColor #000000
  DiamondFontColor #000000
}
skinparam activityArrowColor #000000

' ─── Estados ─────────────────────────────
skinparam state {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
  ArrowColor #000000
  StartColor #000000
  EndColor #000000
}

' ─── Casos de uso ────────────────────────
skinparam usecase {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam actor {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
}

' ─── Clases ──────────────────────────────
skinparam class {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  AttributeFontColor #000000
  StereotypeFontColor #595959
}
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #FFF2CC
skinparam classBorderColor #000000

' ─── Componentes / paquetes ──────────────
skinparam component {
  BackgroundColor #D5E8D4
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F2F2F2
  BorderColor #000000
  FontColor #000000
}
skinparam node {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #E1D5E7
  BorderColor #000000
  FontColor #000000
}

' ─── ER ──────────────────────────────────
skinparam entity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ============================================================
' Diagrama de despliegue — Google Cloud Run (C4 Level 2)
' Ruta: docs/diagramas/plantuml/10_despliegue_cloud.puml
' ============================================================

title Arquitectura de despliegue — Google Cloud Run (europe-west1)

actor "Usuario\n(navegador)" as U
actor "Desarrollador" as D

cloud "Internet" {
}

node "Google Cloud Platform\nProyecto: tfg-llm-benchmarking" {

  node "Cloud Run: tfg-frontend\nhttps://tfg-frontend-u6m6pf6sqq-ew.a.run.app\nnginx:1.27-alpine · 256 MiB · min=0" as FE {
    component "nginx.conf.template\nProxy /api/ → BACKEND_URL\nSirve React SPA (dist/)" as NGINX
  }

  node "Cloud Run: tfg-backend\nhttps://tfg-backend-u6m6pf6sqq-ew.a.run.app\npython:3.11-slim · 512 MiB · min=0" as BE {
    component "uvicorn (1 worker)\nFastAPI application\n→ Alembic migrations on start" as UVICORN
  }

  database "Cloud SQL: tfg-pg\nPostgreSQL 15 · db-f1-micro\neurope-west1-d" as DB

  node "Artifact Registry\neurope-west1-docker.pkg.dev\ntfg-llm-benchmarking/tfg-llms" as AR {
    component "backend:latest" as IMGB
    component "frontend:latest" as IMGF
  }

  node "Secret Manager" as SM {
    component "DATABASE_URL\nSECRET_KEY\nANTHROPIC_API_KEY\nOPENAI_API_KEY\nGOOGLE_API_KEY\nXAI_API_KEY\nALLOWED_ORIGINS" as SECRETS
  }

  node "Cloud Build\n(E2_HIGHCPU_8)" as CB {
    component "cloudbuild.yaml\nbuild → push → deploy" as PIPELINE
  }

  node "Cloud Run Job: seed-admin\n(ejecución única al bootstrap)" as JOB {
    component "scripts/seed_admin.py" as SEED
  }
}

cloud "APIs LLM externas" {
  component "api.anthropic.com\n(Claude Sonnet 4.6)" as CLAUDE
  component "api.openai.com\n(GPT-4o / gpt-image-1)" as OPENAI
  component "generativelanguage.googleapis.com\n(Gemini 2.5 Flash / Imagen 4)" as GEMINI
  component "api.x.ai\n(Grok 4.3)" as GROK
}

' Conexiones principales
U -down-> FE : HTTPS (navegador)
FE -down-> BE : HTTPS /api/v1/...\n(proxy Nginx)
BE -down-> DB : Unix socket\n/cloudsql/tfg-llm-benchmarking:europe-west1:tfg-pg\n(Cloud SQL Auth Proxy integrado)

' Backend → APIs LLM
BE -right-> CLAUDE : HTTPS + API key
BE -right-> OPENAI : HTTPS + API key
BE -right-> GEMINI : HTTPS + API key
BE -right-> GROK : HTTPS + API key

' Build pipeline
D -down-> CB : gcloud builds submit\n--config=cloudbuild.yaml
CB -down-> AR : docker push
AR -down-> FE : deploy image
AR -down-> BE : deploy image

' Secretos
SM -up-> BE : --update-secrets (inyección en arranque)

' Job seed
JOB -down-> DB : INSERT admin user (bootstrap)

note bottom of DB
  Cloud SQL Auth Proxy está integrado
  en Cloud Run: no hay tráfico de red
  expuesto entre backend y BD.
  Conexión via socket Unix local.
  Coste: ~7€/mes activa.
  Puede detenerse entre sesiones.
end note

note right of FE
  min-instances=0: escala a cero.
  Coste = 0€ en inactividad.
  Cold start: 2-3 segundos.
  Calentar antes de demo con:
  curl /api/v1/health
end note

@enduml
