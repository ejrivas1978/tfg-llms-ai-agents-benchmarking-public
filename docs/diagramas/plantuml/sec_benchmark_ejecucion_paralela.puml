' ============================================================
' Secuencia: Ejecucion paralela del benchmark - 4 LLMs (RF-07)
' Ruta: docs/diagramas/plantuml/sec_benchmark_ejecucion_paralela.puml
'
' POST /api/v1/benchmarks/run dispara el motor paralelo:
'   - BenchmarkService valida cuota/actor.
'   - LLMRunner llama a los 4 clientes con asyncio.gather().
'   - Cada cliente devuelve ResultadoLLM o excepcion capturada.
'   - El tiempo total ~= max(T_i), no la suma.
'   - Categoria imagen generativa: Claude no participa (solo 3 LLMs).
'
' La fase de calculo de metricas y persistencia esta en
' sec_benchmark_persistencia.
' ============================================================

actor "Usuario web o admin\n(autenticado)" as U
participant "BenchmarkPage\n(React)" as BP
participant "benchmarkApi\n(axios)" as API
participant "POST /benchmarks/run\n(FastAPI)" as R
participant "BenchmarkService" as BS
participant "runner.py\n(asyncio.gather)" as LR
participant "Claude\nSonnet 4.6" as CL
participant "GPT-4o" as OA
participant "Gemini\n2.5 Flash" as GE
participant "Grok 4.3" as GR

U -> BP : selecciona categoria + prompt\n(o sube imagen / fichero)
activate BP
BP -> BP : valida cliente:\n  nick OK, sin pendiente,\n  cuota > 0 [RF-36]
BP -> API : ejecutarBenchmark({\n  nickname, categoria, prompt,\n  imagen_base64?, subcat_imagen?\n})
note right of API : requestInterceptor inyecta\nAuthorization: Bearer <JWT>
activate API
API -> R : POST /api/v1/benchmarks/run
activate R
R -> R : get_actor_benchmark(JWT)\n  -> UsuarioApp + cuota
R -> BS : ejecutar(peticion, actor)
activate BS
BS -> LR : ejecutar_benchmark(prompt, subcat, imagen?)
activate LR

par asyncio.gather(return_exceptions=True)
  LR ->> CL : messages.create(prompt)
  CL -->> LR : ResultadoLLM (claude)
also
  LR ->> OA : chat.completions.create(prompt)
  OA -->> LR : ResultadoLLM (openai)
also
  LR ->> GE : generate_content(prompt)
  GE -->> LR : ResultadoLLM (gemini)
also
  LR ->> GR : chat.completions.create(prompt)
  GR -->> LR : ResultadoLLM (grok)
end

LR --> BS : list[ResultadoLLM]\ntiempo total ~= max(T_i)
deactivate LR

note over BS,LR : continua en\nsec_benchmark_persistencia

deactivate BS
deactivate R
deactivate API
deactivate BP

@enduml
