' ============================================================
' Casos de uso del usuario web — Acceso e identidad
' Subgrupo 1 de 4 (RF-01 a RF-06)
' Ruta: docs/diagramas/plantuml/01a_cu_usuario_acceso.puml
'
' Layout top-to-bottom (sin "left to right") para distribución
' horizontal de los casos de uso y un diagrama ancho en vez de alto.
' ============================================================

actor "Usuario web\n(nick)" as U

rectangle "Acceso e identidad (RF-01 a RF-06)" {
  usecase "CU-01\nVerificar si\nnick existe\n(RF-01)" as CU01
  usecase "CU-02\nSolicitar acceso\n(alta pendiente)\n(RF-02)" as CU02
  usecase "CU-03\nIniciar sesión\nnick + contraseña\n(RF-03)" as CU03
  usecase "CU-04\nRegenerar\ncontraseña\n(RF-04)" as CU04
  usecase "CU-05\nVer guía de\nbienvenida\n(RF-05)" as CU05
  usecase "CU-06\nSolicitar\nampliación cuota\n(RF-06)" as CU06
}

U --> CU01
U --> CU02
U --> CU03
U --> CU04
U --> CU05
U --> CU06

CU03 ..> CU01 : <<include>>
CU02 ..> CU01 : <<extend>>

@enduml
