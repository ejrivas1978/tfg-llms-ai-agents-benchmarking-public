' ============================================================
' Secuencia: Alta de cuenta nueva (RF-02)
' Ruta: docs/diagramas/plantuml/sec_usuario_registro.puml
'
' Endpoint POST /api/v1/usuarios/registrar (rate-limit 5/min).
' La cuenta queda en estado pendiente_acceso hasta que un admin la
' habilita (ver sec_admin_post_login para el flujo de aprobacion).
'
' UsuarioAppAuthService.registrar() hashea con bcrypt antes de
' insertar (Security.hash_password()).
' ============================================================

actor "Usuario web" as U
participant "NickPage\n(React)" as NP
participant "usuarioApi\n(axios)" as API
participant "POST /usuarios/registrar\n(FastAPI)" as REG
participant "UsuarioAppAuthService" as SVC
participant "Security" as SEC
participant "UsuarioAppRepository" as REPO
database "PostgreSQL\nusuarios_app" as DB

note over U,NP : el paso previo (verificar nick) determino que el nick NO existia\nver sec_usuario_verificar_nick

U   -> NP  : introduce contrasena + confirmacion
activate NP
NP  -> API : registrarUsuario({ nick, password })
activate API
API -> REG : POST /api/v1/usuarios/registrar\nBody: { nick, password }
note right of REG : rate-limit: 5/min por IP
activate REG
REG -> SVC : registrar(nick, password)
activate SVC
note right of SVC
  PeticionRegistro (Pydantic) aplica
  field_validator: nick.strip().lower()
  case-insensitive.
end note
SVC -> SEC : hash_password(password)
SEC --> SVC : bcrypt_hash
SVC -> REPO : crear(nick, hash)
activate REPO
REPO -> DB : INSERT INTO usuarios_app\n(nick, password_hash,\n estado='pendiente_acceso',\n cuota_asignada=0,\n consultas_usadas=0)
DB --> REPO : usuario.id
REPO --> SVC : UsuarioApp
deactivate REPO
SVC --> REG : RespuestaUsuarioApp
deactivate SVC
REG --> API : HTTP 201 Created
deactivate REG
API --> NP : { id, nick, estado: pendiente_acceso, ... }
deactivate API
NP --> U   : "Tu solicitud ha sido enviada.\nEspera aprobacion del administrador."
deactivate NP

@enduml
