' ============================================================
' Secuencia: Solicitud de borrado de evaluacion — Parte 1/2
' Ruta: docs/diagramas/plantuml/sec_solicitud_borrado_p1.puml
' Cubre: RF-32 (usuario solicita borrado de su evaluacion).
' Continua en sec_solicitud_borrado_p2 (admin aprueba o rechaza).
' ============================================================

title Solicitud de borrado — Parte 1/2: Usuario (RF-32)

actor "Usuario web\n(evaluador)" as Usuario
participant "HistorialPage\n/ ConfirmModal" as UI
participant "benchmarkApi.ts" as ApiU
participant "POST /usuarios\n/evaluaciones/{id}\n/solicitar-borrado" as RouterU
participant "BenchmarkEvaluacion\nRepository" as Repo
database "PostgreSQL" as DB

note over Usuario, DB
  ════════════════════════════════════════
   Parte 1/2 — Usuario solicita borrado
  ════════════════════════════════════════
end note

== 1 · Usuario solicita el borrado (RF-32) ==

Usuario -> UI : pulsa "Solicitar borrado"\nen fila de evaluacion completada
UI -> UI : abre ConfirmModal\n(muestra prompt y consecuencias)
Usuario -> UI : confirma la solicitud

UI -> ApiU : solicitarBorradoEvaluacion(nick, id)
ApiU -> RouterU : POST /usuarios/evaluaciones/{id}/solicitar-borrado\nAuthorization: Bearer JWT

RouterU -> Repo : marcar_solicitud_borrado(id, nick)
Repo -> DB : SELECT status, nickname\nFROM benchmark_evaluaciones\nWHERE id = {id}

alt evaluacion no existe
  DB --> Repo : 0 filas
  Repo --> RouterU : "no_encontrada"
  RouterU --> ApiU : 404 Not Found
  ApiU --> UI : toast error "Evaluacion no encontrada"
else nick no coincide
  DB --> Repo : nickname != nick
  Repo --> RouterU : "sin_permiso"
  RouterU --> ApiU : 403 Forbidden
  ApiU --> UI : toast error "Sin permiso"
else ya en solicitud_borrado
  DB --> Repo : status = solicitud_borrado
  Repo --> RouterU : "ya_solicitada"
  RouterU --> ApiU : 409 Conflict
  ApiU --> UI : toast error "Solicitud ya activa"
else evaluacion valida y propietario
  Repo -> DB : UPDATE status = 'solicitud_borrado'\nWHERE id = {id}
  DB --> Repo : OK
  Repo --> RouterU : evaluacion actualizada
  RouterU --> ApiU : 200 OK
  ApiU --> UI : invalidar cache historial
  UI -> UI : fila muestra badge "Pend. borrado"\n(estado readonly, sin valorar)
  UI --> Usuario : toast "Solicitud enviada al administrador"
end

note over Usuario, DB
  ════════════════════════════════════════
   Continua en sec_solicitud_borrado_p2
   (admin aprueba o rechaza, RF-33)
  ════════════════════════════════════════
end note

@enduml
