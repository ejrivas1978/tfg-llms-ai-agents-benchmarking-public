' ============================================================
' Secuencia: Response interceptor axios - manejo del 401
' Ruta: docs/diagramas/plantuml/sec_jwt_response_401.puml
'
' Cuando el backend responde 401 Unauthorized (token expirado o
' invalido), el interceptor de respuesta de axios:
'   1. Limpia el token del usuarioStore y adminStore.
'   2. Navega a "/" (NickPage) con navigate replace.
'   3. Rechaza la promesa sin reintentar (no hay refresh token).
'
' Duracion de sesion: 1h (usuario) o lo configurado en settings
' (admin).
' ============================================================

participant "Componente React" as COMP
participant "axios" as AX
participant "FastAPI\nendpoint protegido" as API
participant "Response Interceptor" as RS
participant "usuarioStore" as US
participant "adminStore" as AS
participant "Router React\n(navigate)" as NAV

COMP -> AX : peticion autenticada
activate AX
AX -> API : con Bearer token (expirado)
API --> AX : HTTP 401 Unauthorized
AX -> RS : interceptor onResponse(error)
activate RS
RS -> RS : error.response.status === 401

RS -> US : usuarioStore.logout()
note right of RS
  elimina token, nick, cuota
  del store y de localStorage
end note

RS -> AS : adminStore.clearToken()
note right of RS
  elimina token admin
  del sessionStorage
end note

RS -> NAV : navigate("/", { replace: true })
note right of RS
  RutaProtegida detecta nick=null
  y redirige al login automaticamente
end note

RS --> AX : rechaza promesa (no reintenta)
deactivate RS
AX --> COMP : error - sesion cerrada
deactivate AX

note over COMP,NAV
  El usuario vuelve a NickPage y debe
  autenticarse de nuevo. Si tenia trabajo
  sin guardar (formularios), se pierde.
end note

@enduml
