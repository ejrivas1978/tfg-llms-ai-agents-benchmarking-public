' ============================================================
' Secuencia: Request interceptor de axios - inyeccion del JWT
' Ruta: docs/diagramas/plantuml/sec_jwt_request_interceptor.puml
'
' El interceptor de petición de axios anade el header
' Authorization: Bearer <JWT> con el token del usuarioStore o, en
' su defecto, del adminStore. Si ninguno tiene token, la petición
' sale sin Authorization (uso para endpoints publicos como
' /verificar/{nick} o /stats).
' ============================================================

participant "Componente React\n(servicio)" as COMP
participant "axios\n(benchmarkApi.ts /\nadminApi.ts /\nusuarioApi.ts)" as AX
participant "Request Interceptor" as RQ
participant "usuarioStore\n(Zustand)" as US
participant "adminStore\n(Zustand)" as AS
participant "FastAPI\nendpoint protegido" as API

COMP -> AX : llamada (p. ej. ejecutarBenchmark)
activate AX
AX -> RQ : interceptor onRequest(config)
activate RQ
RQ -> US : usuarioStore.getState().token
US --> RQ : token_usuario | null

alt token_usuario existe
  RQ -> RQ : config.headers.Authorization\n  = "Bearer " + token_usuario
else token_usuario == null
  RQ -> AS : adminStore.getState().token
  AS --> RQ : token_admin | null
  alt token_admin existe
    RQ -> RQ : config.headers.Authorization\n  = "Bearer " + token_admin
  else ninguno existe
    note right of RQ
      la petición sale sin Authorization;
      valida en endpoints publicos
      (verificar nick, stats)
    end note
  end
end

RQ --> AX : config con header inyectado
deactivate RQ
AX -> API : envia la peticion
note right of AX
  la validacion JWT en el backend
  esta en sec_jwt_backend_validation
end note
deactivate AX

@enduml
