@startuml act_evaluacion_completa

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' Inyectado por docs/diagramas/plantuml/_normalizar_estilo_claro.py
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

' Notas: amarillo palido, texto negro, borde naranja oscuro.
skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

' Titulos
skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

' Divisores y headers
skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

' ─── Secuencia ───────────────────────────
skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ─── Actividad ───────────────────────────
skinparam activity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  StartColor #000000
  EndColor #000000
  DiamondBackgroundColor #DAE8FC
  DiamondBorderColor #000000
  DiamondFontColor #000000
}
skinparam activityArrowColor #000000

' ─── Estados ─────────────────────────────
skinparam state {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
  ArrowColor #000000
  StartColor #000000
  EndColor #000000
}

' ─── Casos de uso ────────────────────────
skinparam usecase {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam actor {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
}

' ─── Clases ──────────────────────────────
skinparam class {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  AttributeFontColor #000000
  StereotypeFontColor #595959
}
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #FFF2CC
skinparam classBorderColor #000000

' ─── Componentes / paquetes ──────────────
skinparam component {
  BackgroundColor #D5E8D4
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F2F2F2
  BorderColor #000000
  FontColor #000000
}
skinparam node {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #E1D5E7
  BorderColor #000000
  FontColor #000000
}

' ─── ER ──────────────────────────────────
skinparam entity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' Diagrama: Actividad — Flujo de evaluacion humana
' Proyecto: TFG LLM Benchmarking — Emilio Javier Rivas

|Usuario Web|
start

:Introduce nick en NickPage;

|Backend|
:GET /usuarios/verificar/{nick}\nconsulta usuarios_app;

|Usuario Web|
if (Nick existe?) then (si)
  :Introduce contrasena;
  |Backend|
  :POST /usuarios/login\nverifica bcrypt + emite JWT 1h;
  |Usuario Web|
  if (Login correcto?) then (si)
    if (Estado habilitado?) then (si)
      :JWT guardado en usuarioStore\n(tipo=usuario_app, id,\n es_admin, es_root);
    else (no)
      :Mensaje pendiente de aprobacion;
      stop
    end if
  else (no)
    :Error credenciales;
    stop
  end if
else (no)
  :Registro — estado pendiente_acceso;
  stop
end if

if (guia_vista=false?) then (si)
  :Muestra OnboardingGuide 7 pasos;
  :PATCH /usuarios/marcar-guia-vista;
end if

:Muestra listado fijo de modelos\nparticipantes encima del PRIMER PASO;

partition "PRIMER PASO - Seleccionar categoria" {
  :Grid de categorias visible\n(parpadea hasta que se hace click);
  note right
    Estado inicial: categoria = null
    (sin categoría por defecto)
  end note
  :Usuario hace click en una categoria;

  if (Evaluacion pendiente?) then (si)
    :Modal "Tienes una evaluacion pendiente"\nboton "Ir a evaluarla";
    note right
      Bloquea avance al PASO 2/3
      hasta que se resuelva la
      evaluacion pendiente.
    end note
    stop
  elseif (Cuota agotada y sin pendiente?) then (si)
    if (Ya solicito?\n(consultasSolicitadas\n  o estado=pendiente_ampliar_tokens)) then (si)
      :Modal "Pendiente de ampliacion"\nboton "Entendido";
      :Banner verde\n"Pendiente de ampliacion\nde cuota por el admin";
      stop
    else (no)
      :Modal "Cuota agotada"\nboton "Solicitar Consultas";
      :Solicita consultas\n(consultasSolicitadas=true);
      stop
    endif
  endif

  :Auto-scroll suave\nhacia PASO 2;
}

partition "SEGUNDO PASO - SubcatPanel (solo si hay categoria)" {
  if (categoria == 'libre'?) then (si)
    :Salta SubcatPanel\n(prompt = libre);
  else (no)
    :Muestra SubcatPanel\n(subcategoria o\n texto+idioma traduccion);
    :Usuario elige subcategoria\no introduce texto+idioma;
  endif
  :Auto-scroll suave\nhacia PASO 3;
}

partition "TERCER PASO - Prompt + listado + ejecucion" {
  note right
    Aparece solo cuando:
     - categoria === 'libre', o
     - hay prompt construido
       (subcategoria elegida o
        texto+idioma en traduccion)
  end note
  :Muestra prompt construido\n+ botones + listado de modelos;
  :Pulsa Ejecutar comparativa;
}

|Backend|
:POST /benchmarks/run\n(prompt + prompt_en opcional, ADR-029);
if (¿Categoria bilingue ES/EN\ny prompt_en presente?) then (sí)
  :asyncio.gather — 4 LLMs en paralelo\nidioma_prompt = 'es';
  :asyncio.gather — 4 LLMs en paralelo\nidioma_prompt = 'en'\n(segunda ronda secuencial);
else (no)
  :asyncio.gather — 4 LLMs en paralelo\nidioma_prompt = 'es' (default);
endif
:Calcula 10 metricas por respuesta;
:status = completada · consultas_usadas+=1\n(la consulta sigue contando 1 aun con 8 respuestas);

|Usuario Web|
:Ve 4 BenchmarkCard ES + AutoStats\n(acordeón "Ver respuesta en inglés"\nen cada tarjeta si es bilingüe);
:Puntua con 1-5 estrellas cada respuesta ES\n(las EN no se valoran, ADR-029);

partition "Ranking - slots vacios + pool de LLMs" {
  :Slots numerados (1.º..N) vacios\n+ chips de LLM en pool inferior;
  note right
    No hay aleatorizacion inicial. El humano
    debe ARRASTRAR cada chip desde
    el pool a un slot numerado.
    Reglas DnD:
     - pool -> slot vacio: asigna
     - pool -> slot ocupado: el
       ocupante vuelve al pool
     - slot -> slot: swap
     - slot -> pool: libera
  end note
  :Humano arrastra cada LLM\ndesde pool a un slot numerado\n(4 veces texto / 3 veces imagen);
  :rankingCompleto = todos los\nslots ocupados;
}

if (rankingCompleto && todosConRating?) then (si)
  :Boton "Guardar evaluacion" se\nhabilita y parpadea\n(animate-pulse-strong);
  note right
    Indicadores * y ✓ visibles
    en los titulos "Puntuacion"
    y "Ranking de preferencia".
    YA NO existe el ConfirmModal
    "No has modificado el orden..."
    porque el drag es obligatorio.
  end note
  :Pulsa Guardar evaluacion;
  |Backend|
  :POST /evaluaciones — INSERT x4 user_evaluations\n(orden = slots: cada posicion contiene\nel id del LLM asignado);
  |Usuario Web|
  :evaluada=true en historialStore;
  :Puede ejecutar nueva comparativa;
else (no)
  :Aviso validacion pendiente\n(boton Guardar deshabilitado);
endif

stop

@enduml
