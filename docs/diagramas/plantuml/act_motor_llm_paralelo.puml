' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
