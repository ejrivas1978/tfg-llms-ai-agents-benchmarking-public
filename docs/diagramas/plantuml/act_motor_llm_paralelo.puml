' ============================================================
' Diagrama de actividad — Motor LLM paralelo (asyncio.gather)
' Ruta: docs/diagramas/plantuml/09_motor_llm_paralelo.puml
' ============================================================

title Motor LLM — Ejecución paralela con asyncio.gather\n(app/llm_engine/runner.py)

start

:Recibir PeticionBenchmark\n(prompt, category, subcat, imagen_base64?);

fork
  :AnthropicClient.call(prompt)\n→ Claude Sonnet 4.6\nSDK: anthropic (async);
  :medir latency_ms\ncalcular métricas texto\ncost_usd = tok_entrada × $3/M\n      + tok_salida × $15/M;
fork again
  :OpenAIClient.call(prompt)\n→ GPT-4o\nSDK: openai (async);
  :medir latency_ms\ncalcular métricas texto/imagen\ncost_usd = tok_entrada × $2.5/M\n       + tok_salida × $10/M;
fork again
  :GeminiClient.call(prompt)\n→ Gemini 2.5 Flash\nSDK: google-generativeai (async);
  :medir latency_ms\ncalcular métricas texto/imagen\ncost_usd = tok_entrada × $0.15/M\n       + tok_salida × $0.60/M;
fork again
  :GrokClient.call(prompt)\n→ Grok 4.3\nHTTP directo (httpx async);
  :medir latency_ms\ncalcular métricas texto/imagen\ncost_usd ≈ tok_entrada × $3/M\n      + tok_salida × $15/M;
end fork

note right
  asyncio.gather(
    claude_coro,
    openai_coro,
    gemini_coro,
    grok_coro,
    return_exceptions=True
  )

  Tiempo total = max(T_claude, T_openai,
                     T_gemini, T_grok)
  en lugar de la suma.
  Un fallo no cancela los demás.
end note

:Recoger list[ResultadoLLM | Exception];

if (¿Hay excepciones capturadas?) then (sí)
  :Convertir Exception\na ResultadoLLM(tuvo_error=True\nerror_message=str(exc));
endif

:Calcular métricas de texto para\ncada ResultadoLLM con tuvo_error=False\n(palabras, diversidad_lexica, parrafos,\ntokens_por_segundo,\nratio_sal_ent, coste_por_100_palabras);

if (¿category == imagen?) then (sí)
  :Métricas texto = 0\n(palabras, diversidad, parrafos = 0);
  if (¿subcat == describir?) then (sí)
    :response_text = descripcion\nes_generacion_imagen = False;
  else (generar / logotipo / modificar)
    :imagen_miniatura = base64 JPEG\nes_generacion_imagen = True\ncost_usd = precio fijo/imagen;
  endif
else (texto)
endif

:Devolver list[ResultadoLLM]\na BenchmarkService;

stop

@enduml
