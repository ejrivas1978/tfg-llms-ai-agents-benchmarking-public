' ============================================================
' Casos de uso del administrador — Autenticación
' Subgrupo 1 de 4 (RF-16, RF-17 + bootstrap)
' Ruta: docs/diagramas/plantuml/02a_cu_admin_auth.puml
' ============================================================

actor "Administrador\n(root o promovido)" as A
actor "Sistema\n(Cloud Run Job)" as S

rectangle "Autenticación admin (RF-16, RF-17)" {
  usecase "CU-A01\nIniciar sesión\nnick + contraseña\n(RF-16)" as CA01
  usecase "CU-A02\nObtener JWT\ncon flag es_root" as CA02
  usecase "CU-A03\nVer perfil admin\n(RF-17)" as CA03
  usecase "CU-A04\nCerrar sesión" as CA04
  usecase "CU-A20\nBootstrap:\ncrear admin root\ninicial" as CA20
}

A --> CA01
A --> CA03
A --> CA04
S --> CA20

CA01 ..> CA02 : <<include>>

note bottom of CA02
  El JWT incluye es_root para que
  el frontend active u oculte los
  botones de promover/degradar
  sin un round-trip extra.
end note

note bottom of CA20
  Cloud Run Job (seed_admin.py).
  Crea el ÚNICO registro con
  es_root=True del sistema.
end note

@enduml
