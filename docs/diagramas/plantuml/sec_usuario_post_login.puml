' ============================================================
' Secuencia: Post-login del usuario web (RF-05 + eval pendiente)
' Ruta: docs/diagramas/plantuml/sec_usuario_post_login.puml
'
' Tras un login exitoso (ver sec_usuario_login_exito), el
' frontend hace dos chequeos antes de habilitar la pagina principal:
'   1. Si guia_vista == False: muestra OnboardingGuide y marca
'      guia_vista en BD (PATCH /usuarios/marcar-guia-vista).
'   2. Comprueba si el usuario tiene una evaluacion completada
'      pendiente de valoracion. Si la hay, muestra popup.
' Despues redirige a BenchmarkPage o HistorialPage segun el caso.
' ============================================================

actor "Usuario web" as U
participant "NickPage\n(React)" as NP
participant "usuarioStore\n(Zustand)" as STORE
participant "usuarioApi\n(axios)" as API
participant "PATCH /usuarios/marcar-guia-vista\n(FastAPI)" as MARK
participant "historialStore\n(Zustand)" as HS
database "PostgreSQL" as DB

note over NP,STORE : el JWT y los datos basicos del usuario\nya estan en usuarioStore tras el login

alt guia_vista == false
  NP --> U : muestra <OnboardingGuide />\n(logo escuela + 7 pasos)
  U -> NP  : cierra la guia
  NP -> API : marcarGuiaVista()
  API -> MARK : PATCH /api/v1/usuarios/marcar-guia-vista\nAuthorization: Bearer JWT
  MARK -> DB : UPDATE usuarios_app SET guia_vista = TRUE
  DB --> MARK : ok
  MARK --> API : 200 RespuestaUsuarioApp
  API --> NP : ok
  NP -> STORE : setGuiaVista(true)
end

NP -> HS : getState().sesiones[nick] ?? []
HS --> NP : lista local de evaluaciones
NP -> NP : busca status='completada'\n  AND evaluada=false

alt hay evaluacion pendiente
  NP --> U : popup "Tienes una evaluacion\npendiente de valorar"
  note right of NP : comprobacion local en historialStore,\nsin round-trip al servidor
else no hay pendiente
  NP --> U : redirige a BenchmarkPage
end

@enduml
