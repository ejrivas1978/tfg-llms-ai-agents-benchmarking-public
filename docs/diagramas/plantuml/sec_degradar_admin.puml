' ============================================================
' Secuencia: Degradar admin / quitar privilegios (RF-31, solo root)
' Ruta: docs/diagramas/plantuml/sec_degradar_admin.puml
'
' Endpoint POST /api/v1/admin/usuarios/{id}/quitar-admin.
' Guards encadenados:
'   - !caller.es_root -> 403
'   - target.es_root -> 400 (no se puede degradar al root)
'   - COUNT admins == 1 -> 400 (no dejar sistema sin admins)
'   - OK -> UPDATE is_admin=False, email=NULL
' El target conserva cuota_asignada y consultas_usadas para que
' pueda volver a usar la aplicacion como usuario web sin perder
' su historial.
' ============================================================

actor "Admin root\n(es_root=True)" as Root
participant "TablaUsuarios.tsx" as UI
participant "adminApi.ts" as API
participant "POST /admin/usuarios/{id}\n/quitar-admin (FastAPI)" as R
participant "UsuarioAppAdminService" as SVC
participant "UsuarioAppRepository" as REPO
database "PostgreSQL\nusuarios_app" as DB

note over Root,UI
  Boton "Quitar admin" visible solo si:
    caller.es_root && target.is_admin
    && !target.es_root
end note

Root -> UI : pulsa "Quitar admin"
activate UI
UI -> UI : abre ConfirmModal destructivo
Root -> UI : confirma
UI -> API : quitarAdminUsuario(token, id)
activate API
API -> R : POST /admin/usuarios/{id}/quitar-admin\nAuthorization: Bearer JWT
activate R
R -> SVC : degradar_admin(caller, id)
activate SVC

alt !caller.es_root
  SVC --> R : HTTPException 403
else target.es_root
  SVC --> R : HTTPException 400\n"No se puede degradar al root"
else solo queda un admin en el sistema
  SVC -> REPO : contar_admins()
  REPO -> DB : SELECT COUNT(*)\nFROM usuarios_app WHERE is_admin = TRUE
  DB --> REPO : 1
  REPO --> SVC : 1
  SVC --> R : HTTPException 400\n"ultimo admin"
else OK
  SVC -> REPO : actualizar_admin(id, is_admin=False, email=NULL)
  REPO -> DB : UPDATE usuarios_app\nSET is_admin = FALSE, email = NULL\nWHERE id = ?
  DB --> REPO : ok
  REPO --> SVC : usuario actualizado
  SVC --> R : RespuestaUsuarioApp
  R --> API : HTTP 200
  API --> UI : usuario actualizado
  UI --> Root : toast "@<nick> ya no es admin"
end
deactivate SVC
deactivate R
deactivate API
deactivate UI

note over DB
  El target conserva:
    cuota_asignada, consultas_usadas
  Cuando vuelva a iniciar sesion
  retomara los limites con esos valores.
  Si quieres "borron y cuenta nueva" usa
  RF-25 (Reset evaluaciones) por separado.
end note

@enduml
