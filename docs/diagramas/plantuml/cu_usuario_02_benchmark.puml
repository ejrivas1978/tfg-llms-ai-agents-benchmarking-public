@startuml cu_usuario_02_benchmark

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' Inyectado por docs/diagramas/plantuml/_normalizar_estilo_claro.py
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

' Notas: amarillo palido, texto negro, borde naranja oscuro.
skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

' Titulos
skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

' Divisores y headers
skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

' ─── Secuencia ───────────────────────────
skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ─── Actividad ───────────────────────────
skinparam activity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  StartColor #000000
  EndColor #000000
  DiamondBackgroundColor #DAE8FC
  DiamondBorderColor #000000
  DiamondFontColor #000000
}
skinparam activityArrowColor #000000

' ─── Estados ─────────────────────────────
skinparam state {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
  ArrowColor #000000
  StartColor #000000
  EndColor #000000
}

' ─── Casos de uso ────────────────────────
skinparam usecase {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam actor {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
}

' ─── Clases ──────────────────────────────
skinparam class {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  AttributeFontColor #000000
  StereotypeFontColor #595959
}
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #FFF2CC
skinparam classBorderColor #000000

' ─── Componentes / paquetes ──────────────
skinparam component {
  BackgroundColor #D5E8D4
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F2F2F2
  BorderColor #000000
  FontColor #000000
}
skinparam node {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #E1D5E7
  BorderColor #000000
  FontColor #000000
}

' ─── ER ──────────────────────────────────
skinparam entity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ============================================================
' Casos de uso del usuario web — Ejecución de benchmark
' Subgrupo 2 de 4 (RF-07 a RF-10, RF-15, RF-34, RF-35)
' Ruta: docs/diagramas/plantuml/cu_usuario_02_benchmark.puml
'
' Layout top-to-bottom para distribución horizontal.
' ============================================================

actor "Usuario web" as U

rectangle "Benchmark (RF-07 a RF-10, RF-15, RF-34, RF-35, RF-36)" {
  usecase "CU-07\nElegir categoría\ny subcategoría\n(RF-07)" as CU07
  usecase "CU-08\nEscribir prompt" as CU08
  usecase "CU-09\nSubir imagen\n(describir)\n(RF-08)" as CU09
  usecase "CU-10\nSubir fichero\n(resumen)\n(RF-09)" as CU10
  usecase "CU-11\nEjecutar benchmark\n4 LLMs en paralelo\n(RF-07, RF-36)" as CU11
  usecase "CU-12\nVer respuestas con\nmétricas automáticas\n(RF-10)" as CU12
  usecase "CU-13\nDescargar imagen\ngenerada\n(RF-15)" as CU13
  usecase "CU-14\nGenerar texto de\nejemplo con LLM\n(RF-34)" as CU14
  usecase "CU-15\nRecuperar texto de\nentrada desde\nhistorial (RF-35)" as CU15
}

U --> CU07
U --> CU08
U --> CU09
U --> CU10
U --> CU11
U --> CU12
U --> CU13
U --> CU14
U --> CU15

CU11 ..> CU07 : <<include>>
CU11 ..> CU08 : <<include>>
CU09 ..> CU08 : <<extend>>
CU10 ..> CU08 : <<extend>>
CU14 ..> CU08 : <<extend>>
CU15 ..> CU14 : <<extend>>

note right of CU11
  asyncio.gather → 4 LLMs en paralelo
  Tiempo total = max(T_i)
  Imagen: solo 3 proveedores
end note

note right of CU14
  GET /benchmarks/texto-ejemplo
  LLM seleccionable (Auto=más barato:
  Gemini > Grok > GPT-4o > Claude).
  ~300 palabras, tema aleatorio.
  No consume cuota. Requiere JWT.
  El texto generado se persiste en BD
  (texto_entrada_autogenerado=TRUE)
  y es recuperable desde el historial
  vía acordeón en EvalViewModal
  (RF-35 / ADR-030).
end note

note right of CU15
  Acordeón "Ver texto original
  generado automáticamente"
  en EvalViewModal (historial).
  Solo visible cuando
  texto_entrada_autogenerado=TRUE.
  ADR-030.
end note

@enduml
