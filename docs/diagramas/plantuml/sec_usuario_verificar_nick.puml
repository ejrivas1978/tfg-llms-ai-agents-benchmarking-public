' ============================================================
' Secuencia: Verificacion de nick previo al login/registro (RF-01)
' Ruta: docs/diagramas/plantuml/sec_usuario_verificar_nick.puml
'
' Cubre el endpoint GET /api/v1/usuarios/verificar/{nick}.
' Rate-limit: 20 peticiones/min por IP (mitigacion de enumeracion).
' La respuesta NO revela ni el estado ni la contrasena, solo si el
' nick existe en la tabla usuarios_app.
'
' Actores y componentes referenciados:
'   - NickPage (frontend)
'   - usuarioApi (axios)
'   - GET /api/v1/usuarios/verificar/{nick} (FastAPI router)
'   - UsuarioAppRepository.obtener_por_nick()
'   - Tabla usuarios_app
' ============================================================

actor "Usuario web" as U
participant "NickPage\n(React)" as NP
participant "usuarioApi\n(axios)" as API
participant "GET /usuarios/verificar/{nick}\n(FastAPI)" as VER
participant "UsuarioAppRepository" as REPO
database "PostgreSQL\nusuarios_app" as DB

U   -> NP   : introduce nick
activate NP
NP  -> API  : verificarNick(nick)
activate API
API -> VER  : GET /api/v1/usuarios/verificar/{nick}
note right of VER : rate-limit: 20/min por IP
activate VER
VER -> VER  : nick = nick.strip().lower()
note right of VER
  Normalizacion case-insensitive
  aplicada en el path param antes
  de consultar la BD.
end note
VER -> REPO : obtener_por_nick(nick)
activate REPO
REPO -> DB  : SELECT * FROM usuarios_app WHERE nick = ?
DB --> REPO : UsuarioApp | None
REPO --> VER : usuario | None
deactivate REPO
VER --> API : { "existe": bool }
deactivate VER
API --> NP  : respuesta
deactivate API

alt existe == false (primer acceso)
  NP --> U  : muestra formulario de REGISTRO
  note right of NP
    continua en
    sec_usuario_registro
  end note
else existe == true
  NP --> U  : muestra formulario de LOGIN
  note right of NP
    continua en
    sec_usuario_login_exito
    o sec_usuario_login_errores
  end note
end
deactivate NP

@enduml
