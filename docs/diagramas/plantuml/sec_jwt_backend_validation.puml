' ============================================================
' Secuencia: Validacion del JWT en el backend
' Ruta: docs/diagramas/plantuml/sec_jwt_backend_validation.puml
'
' La dependencia FastAPI `get_actor_benchmark` (o
' `get_current_user`) decodifica el token, valida la firma y la
' expiracion, carga el usuario y devuelve un actor segun el tipo:
'   - tipo='usuario_app' -> UsuarioApp con cuota.
'   - is_admin=True -> actor=None (admin sin restriccion de cuota).
' Errores: 401 token invalido/expirado, 403 usuario inhabilitado.
' ============================================================

participant "axios" as AX
participant "FastAPI router\n(endpoint protegido)" as API
participant "get_actor_benchmark\n(Depends)" as DEP
participant "Security\ndecode_access_token" as SEC
participant "UsuarioAppRepository" as REPO
database "PostgreSQL\nusuarios_app" as DB

AX -> API : peticion con Bearer JWT
activate API
API -> DEP : dependencia FastAPI
activate DEP
DEP -> SEC : decode_access_token(token)
activate SEC
SEC -> SEC : jwt.decode(token,\n  SECRET_KEY, HS256)

alt token invalido o expirado
  SEC --> DEP : raise JWTError
  DEP --> API : HTTPException 401 Unauthorized
  API --> AX : 401
  note right of AX
    el response interceptor cierra
    sesion - ver sec_jwt_response_401
  end note
else token valido
  SEC --> DEP : payload { sub, tipo, exp }
  deactivate SEC

  alt payload.tipo == "usuario_app"
    DEP -> REPO : obtener_por_id(int(payload.sub))
    activate REPO
    REPO -> DB : SELECT FROM usuarios_app WHERE id = ?
    DB --> REPO : UsuarioApp
    REPO --> DEP : usuario
    deactivate REPO
    alt estado != habilitado OR cuota agotada
      DEP --> API : HTTPException 403 Forbidden
    else usuario valido con cuota
      DEP --> API : actor = UsuarioApp
    end
  else admin (is_admin == True)
    DEP -> REPO : obtener_por_id(payload.sub)
    activate REPO
    REPO -> DB : SELECT FROM usuarios_app WHERE id = ?
    DB --> REPO : UsuarioApp admin
    REPO --> DEP : usuario
    deactivate REPO
    DEP --> API : actor = None
    note right of DEP
      actor=None indica acceso
      sin restriccion de cuota
    end note
  end
  API -> API : procesa endpoint con actor
  API --> AX : HTTP 200 (respuesta del endpoint)
end
deactivate DEP
deactivate API

@enduml
