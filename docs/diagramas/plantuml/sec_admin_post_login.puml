' ============================================================
' Secuencia: Post-login del administrador (carga inicial)
' Ruta: docs/diagramas/plantuml/sec_admin_post_login.puml
'
' Tras un login admin exitoso (sec_admin_login), el frontend:
'   1. Solicita el listado de usuarios para detectar pendientes
'      de aprobacion y mostrar popup informativo.
'   2. Navega a /historial (HistorialPage en modo admin).
'   3. La tabla habilita los botones de promover/degradar solo si
'      adminStore.es_root == true.
' ============================================================

actor "Administrador" as AD
participant "NickPage\n(React)" as NP
participant "adminApi\n(axios)" as API
participant "GET /admin/usuarios\n(FastAPI)" as USR
database "PostgreSQL\nusuarios_app" as DB
participant "HistorialPage\n(TablaAdmin +\nTablaUsuarios)" as HP

note over NP : adminStore ya contiene token + es_root\ntras sec_admin_login

NP -> API : listarUsuariosAdmin(token)
activate API
API -> USR : GET /api/v1/admin/usuarios\nAuthorization: Bearer JWT
activate USR
USR -> DB : SELECT FROM usuarios_app ORDER BY created_at DESC
DB --> USR : items
USR --> API : RespuestaListaUsuariosApp
deactivate USR
API --> NP : items
deactivate API

alt hay N usuarios con estado = pendiente_acceso
  NP --> AD : popup "N usuarios pendientes\nde aprobacion"
end

NP -> HP : navega a /historial
activate HP
HP -> HP : esAdmin = adminStore.token != null -> true

alt es_root == true
  HP --> AD : muestra TablaAdmin + TablaUsuarios\ncon botones "Promover" y "Quitar admin"
  note right of HP
    los flujos completos en
    sec_promover_admin
    sec_degradar_admin
  end note
else es_root == false (admin promovido)
  HP --> AD : muestra TablaAdmin + TablaUsuarios\nSIN gestion de roles
end
deactivate HP

@enduml
