' ============================================================
' Secuencia: Promover usuario a admin (RF-30, solo root)
' Ruta: docs/diagramas/plantuml/sec_promover_admin.puml
'
' Endpoint POST /api/v1/admin/usuarios/{id}/promover-admin.
' Solo el admin con es_root=True puede ejecutarlo. Se exige un
' email no nulo (sirve como identificador alterno del admin nuevo).
' Cadena de guards en el servicio:
'   - !caller.es_root -> 403
'   - target.is_admin -> 400 "ya es administrador"
'   - email duplicado -> 409
'   - OK -> UPDATE is_admin=True, email=...
' ============================================================

actor "Admin root\n(es_root=True)" as Root
participant "TablaUsuarios.tsx" as UI
participant "adminApi.ts" as API
participant "POST /admin/usuarios/{id}\n/promover-admin (FastAPI)" as R
participant "UsuarioAppAdminService" as SVC
participant "UsuarioAppRepository" as REPO
database "PostgreSQL\nusuarios_app" as DB

note over Root,UI
  Boton "Promover" visible solo si:
    caller.es_root && !target.is_admin
    && target.estado == 'habilitado'
end note

Root -> UI : pulsa "Promover"
activate UI
UI -> UI : abre PromoteModal(nick)
Root -> UI : escribe email + confirmar
UI -> UI : valida regex email en cliente
UI -> API : promoverAdminUsuario(token, id, email)
activate API
API -> R : POST /admin/usuarios/{id}/promover-admin\nBody: { email }\nAuthorization: Bearer JWT
activate R
R -> R : Depends(get_current_user)\n  -> caller (admin actual)
R -> SVC : promover_admin(caller, id, email)
activate SVC

alt !caller.es_root
  SVC --> R : HTTPException 403\n"Solo el admin root puede promover"
  R --> API : 403
  API --> UI : error
  UI --> Root : toast rojo
else caller.es_root == True
  SVC -> REPO : obtener_por_id(id)
  REPO -> DB : SELECT FROM usuarios_app WHERE id = ?
  DB --> REPO : target
  REPO --> SVC : target

  alt target.is_admin == True
    SVC --> R : HTTPException 400\n"ya es administrador"
  else email duplicado
    SVC -> REPO : existe_email(email, exclude_id=id)
    REPO -> DB : SELECT FROM usuarios_app\nWHERE email = ? AND id <> ?
    DB --> REPO : count > 0
    SVC --> R : HTTPException 409\n"email ya asociado"
  else OK
    SVC -> REPO : actualizar_admin(id, email=email, is_admin=True)
    REPO -> DB : UPDATE usuarios_app\nSET email = ?, is_admin = TRUE\nWHERE id = ?
    DB --> REPO : ok
    REPO --> SVC : usuario actualizado
    SVC --> R : RespuestaUsuarioApp
    R --> API : HTTP 200
    API --> UI : usuario actualizado
    UI -> UI : invalida query 'admin-usuarios'
    UI --> Root : toast verde "@<nick> ahora es admin"
  end
end
deactivate SVC
deactivate R
deactivate API
deactivate UI

@enduml
