@startuml sec_export_csv

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' Inyectado por docs/diagramas/plantuml/_normalizar_estilo_claro.py
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

' Notas: amarillo palido, texto negro, borde naranja oscuro.
skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

' Titulos
skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

' Divisores y headers
skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

' ─── Secuencia ───────────────────────────
skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ─── Actividad ───────────────────────────
skinparam activity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  StartColor #000000
  EndColor #000000
  DiamondBackgroundColor #DAE8FC
  DiamondBorderColor #000000
  DiamondFontColor #000000
}
skinparam activityArrowColor #000000

' ─── Estados ─────────────────────────────
skinparam state {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
  ArrowColor #000000
  StartColor #000000
  EndColor #000000
}

' ─── Casos de uso ────────────────────────
skinparam usecase {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam actor {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
}

' ─── Clases ──────────────────────────────
skinparam class {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  AttributeFontColor #000000
  StereotypeFontColor #595959
}
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #FFF2CC
skinparam classBorderColor #000000

' ─── Componentes / paquetes ──────────────
skinparam component {
  BackgroundColor #D5E8D4
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F2F2F2
  BorderColor #000000
  FontColor #000000
}
skinparam node {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #E1D5E7
  BorderColor #000000
  FontColor #000000
}

' ─── ER ──────────────────────────────────
skinparam entity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ============================================================
' Diagrama de secuencia — Exportar evaluaciones a CSV (admin)
' Ruta: docs/diagramas/plantuml/12_secuencia_export_csv.puml
'
' Cubre: RF-19 (export CSV admin con filtros activos).
' ============================================================

actor "Admin\n(is_admin=True)" as Admin
participant "TablaAdmin.tsx" as UI
participant "adminApi.ts" as API
participant "FastAPI\n/admin/evaluaciones/exportar-csv" as Router
participant "BenchmarkEvaluacion\nRepository" as Repo
participant "admin_export\n_service" as Svc
database "PostgreSQL" as DB
participant "Navegador\n(blob anchor)" as Browser

Admin -> UI : aplica filtros\n(nick, fecha, estado, ...)
Admin -> UI : pulsa "📥 Exportar CSV"
UI -> UI : disabled si total === 0

UI -> API : exportarEvaluacionesCsvAdmin(token, filtros)
note right of API
  aIsoUtc() convierte fechas
  locales del DateTimePicker
  a ISO 8601 UTC antes de
  añadirlas como query params.
end note

API -> Router : GET /admin/evaluaciones/exportar-csv\n?nick=...&categoria=...&fecha_desde=...&fecha_hasta=...\nHeader: Bearer JWT\nresponseType: blob
Router -> Router : Depends(get_current_user) → admin OK
Router -> Repo : listar_para_export(filtros)
Repo -> DB : SELECT BenchmarkEvaluacion\nLEFT JOIN respuestas (selectinload)\nLEFT JOIN respuesta.evaluacion\nWHERE filtros\nORDER BY created_at DESC
note right of Repo
  selectinload evita N+1:
  todas las respuestas y
  valoraciones se cargan en
  una única round-trip.
end note
DB --> Repo : list[BenchmarkEvaluacion]
Repo --> Router : evaluaciones (eager-loaded)

Router -> Svc : generar_csv(evaluaciones)
note right of Svc
  Generador asíncrono que emite
  bytes UTF-8 + BOM y luego una
  fila CSV por respuesta LLM
  (formato tidy/largo, 28 cols).
  Sin textos largos: ni prompt
  ni response_text incluidos.
end note

Router -> Browser : StreamingResponse\nContent-Type: text/csv; charset=utf-8\nContent-Disposition: attachment;\n  filename="benchmark-export-YYYYMMDD-HHMMSS.csv"

loop por cada evaluación
    loop por cada respuesta LLM
        Svc -> Browser : fila CSV (chunk bytes)
    end
end

API -> API : extrae filename\ndel Content-Disposition
API --> UI : { blob, nombre }
UI -> UI : URL.createObjectURL(blob)
UI -> UI : anchor.download = nombre
UI -> UI : anchor.click()
UI --> Admin : toast "CSV exportado (N evaluaciones)"
Browser -> Admin : descarga archivo .csv

note over Admin
  El admin abre el CSV en Excel.
  El BOM UTF-8 garantiza que
  acentos se renderizan bien
  en Windows sin pasos manuales.
end note

@enduml
