@startuml meto_evolucion_modelos

' ============================================================
' Timeline moderno: tarjetas verticales por proveedor
' Diagrama: meto_evolucion_modelos
' ============================================================
skinparam backgroundColor #FAFAFA
skinparam defaultFontName "Arial"
skinparam defaultFontSize 10
skinparam defaultFontColor #2C3E50
skinparam shadowing false

skinparam sequence {
  ArrowColor #FFFFFF
  LifeLineBorderColor #D0D3D4
  LifeLineBackgroundColor #FAFAFA
  ParticipantBackgroundColor #FAFAFA
  ParticipantBorderColor #FAFAFA
  ParticipantFontColor #FAFAFA
  BoxBackgroundColor #FAFAFA
  BoxBorderColor #FAFAFA
  DividerBackgroundColor #ECF0F1
  DividerFontColor #566573
  DividerBorderColor #BFC9CA
}

skinparam note {
  RoundCorner 10
  BorderThickness 1
  FontSize 10
  FontName Arial
}

skinparam title {
  FontColor #1B2631
  FontSize 14
  FontStyle bold
  FontName Arial
}

title Evolución de los modelos LLM en el benchmark\noct 2025 – may 2026

hide footbox

participant "  " as T

