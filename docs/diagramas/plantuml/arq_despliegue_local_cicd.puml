@startuml arq_despliegue_local_cicd

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' Inyectado por docs/diagramas/plantuml/_normalizar_estilo_claro.py
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

' Notas: amarillo palido, texto negro, borde naranja oscuro.
skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

' Titulos
skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

' Divisores y headers
skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

' ─── Secuencia ───────────────────────────
skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ─── Actividad ───────────────────────────
skinparam activity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  StartColor #000000
  EndColor #000000
  DiamondBackgroundColor #DAE8FC
  DiamondBorderColor #000000
  DiamondFontColor #000000
}
skinparam activityArrowColor #000000

' ─── Estados ─────────────────────────────
skinparam state {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
  ArrowColor #000000
  StartColor #000000
  EndColor #000000
}

' ─── Casos de uso ────────────────────────
skinparam usecase {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam actor {
  BackgroundColor #DAE8FC
  BorderColor #000000
  FontColor #000000
}

' ─── Clases ──────────────────────────────
skinparam class {
  BackgroundColor #FFF2CC
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
  AttributeFontColor #000000
  StereotypeFontColor #595959
}
skinparam classAttributeIconSize 0
skinparam classBackgroundColor #FFF2CC
skinparam classBorderColor #000000

' ─── Componentes / paquetes ──────────────
skinparam component {
  BackgroundColor #D5E8D4
  BorderColor #000000
  ArrowColor #000000
  FontColor #000000
}
skinparam package {
  BackgroundColor #F2F2F2
  BorderColor #000000
  FontColor #000000
}
skinparam node {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}
skinparam cloud {
  BackgroundColor #E1D5E7
  BorderColor #000000
  FontColor #000000
}

' ─── ER ──────────────────────────────────
skinparam entity {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' ─── Rectangulos genericos ──────────────
skinparam rectangle {
  BackgroundColor #F8F8F8
  BorderColor #000000
  FontColor #000000
}

' ─── Interfaces ──────────────────────────
skinparam interface {
  BackgroundColor #FFF2CC
  BorderColor #000000
  FontColor #000000
}

' Diagrama: Despliegue — Infraestructura Google Cloud Platform
' Proyecto: TFG LLM Benchmarking — Emilio Javier Rivas

package "Desarrollo Local (Windows 11)" {
  node "Maquina desarrollador" {
    component "PostgreSQL 15 (servicio Windows)" as PG_L
    component "FastAPI uvicorn :8000" as API_L
    component "React + Vite :5173" as FE_L
  }
}

package "CI/CD" {
  node "GitHub ejrivas1978" as GH
  node "Cloud Build (E2_HIGHCPU_8)" {
    component "build backend + frontend" as CB1
    component "push Artifact Registry" as CB2
    component "deploy Cloud Run" as CB3
  }
}

package "Google Cloud Platform — Produccion (europe-west1)" {
  node "Artifact Registry" {
    component "tfg-llms/backend:latest" as IMG_BE
    component "tfg-llms/frontend:latest" as IMG_FE
  }
  node "Secret Manager" {
    component "DATABASE_URL · SECRET_KEY\nANTHROPIC_API_KEY · OPENAI_API_KEY\nGOOGLE_API_KEY · XAI_API_KEY\nALLOWED_ORIGINS" as SM
  }
  node "Cloud Run tfg-frontend\n256Mi · 0-3 instancias" {
    component "nginx (SPA React + proxy /api)" as FE_P
  }
  node "Cloud Run tfg-backend\n512Mi · 0-3 instancias" {
    component "FastAPI uvicorn :8080" as BE_P
    component "Alembic migraciones al arranque" as ALM
  }
  database "Cloud SQL PostgreSQL 15\ndb-f1-micro" as PG_P
}

cloud "APIs LLMs Externas" {
  component "Anthropic · OpenAI · Google · xAI" as LLMS
}

actor "Usuario (navegador)" as U

GH --> CB1 : git push / gcloud builds submit
CB2 --> IMG_BE
CB2 --> IMG_FE
IMG_BE --> BE_P : gcloud run deploy
IMG_FE --> FE_P : gcloud run deploy
SM --> BE_P : secretos en runtime

U --> FE_P : HTTPS
FE_P --> BE_P : HTTP /api/v1/*
BE_P --> PG_P : Cloud SQL socket Unix
BE_P --> LLMS : HTTPS APIs

@enduml
