' ============================================================
' Secuencia: Login del usuario web - ramas de error (RF-03)
' Ruta: docs/diagramas/plantuml/sec_usuario_login_errores.puml
'
' Tres escenarios de error del endpoint POST /usuarios/login, en
' el orden de verificacion del backend:
'   1. Contrasena incorrecta -> 401 + incrementa intentos_fallidos.
'   2. intentos_fallidos >= 5 -> 423 Locked (cuenta bloqueada).
'   3. estado == pendiente_acceso -> 403 acceso no aprobado.
'
' El camino feliz esta en sec_usuario_login_exito.
' ============================================================

actor "Usuario web" as U
participant "NickPage\n(React)" as NP
participant "usuarioApi\n(axios)" as API
participant "POST /usuarios/login\n(FastAPI)" as LOGIN
participant "UsuarioAppAuthService" as SVC
participant "UsuarioAppRepository" as REPO
participant "Security" as SEC
database "PostgreSQL\nusuarios_app" as DB

U   -> NP  : introduce contrasena
NP  -> API : loginUsuario({ nick, password })
API -> LOGIN : POST /api/v1/usuarios/login
LOGIN -> SVC : login(nick, password)
note right of SVC
  PeticionLogin (Pydantic) aplica
  field_validator: nick.strip().lower()
  case-insensitive.
end note
SVC -> REPO : obtener_por_nick(nick)
REPO -> DB : SELECT ... WHERE nick = ?
DB --> REPO : usuario
REPO --> SVC : usuario

alt 1) Contrasena incorrecta
  SVC -> SEC : verify_password(password, hash)
  SEC --> SVC : False
  SVC -> REPO : incrementar_intentos(usuario.id)
  REPO -> DB : UPDATE intentos_fallidos += 1
  SVC --> LOGIN : HTTPException 401\n"Credenciales invalidas"
  LOGIN --> API : 401
  API --> NP : error
  NP --> U : "Nick o contrasena incorrectos"

else 2) Cuenta bloqueada (intentos_fallidos >= 5)
  SVC -> SVC : usuario.intentos_fallidos >= 5
  SVC --> LOGIN : HTTPException 423\n"Cuenta bloqueada por multiples intentos"
  LOGIN --> API : 423 Locked
  API --> NP : error
  NP --> U : "Demasiados intentos.\nContacta con el administrador."

else 3) Estado pendiente_acceso
  SVC -> SVC : usuario.estado == 'pendiente_acceso'
  SVC --> LOGIN : HTTPException 403\n"Acceso no aprobado"
  LOGIN --> API : 403
  API --> NP : error
  NP --> U : "Tu cuenta esta pendiente\nde aprobacion."
end

note over U,NP
  En los tres casos el usuario
  permanece en NickPage y puede
  reintentar (sujeto a rate-limit).
end note

@enduml
