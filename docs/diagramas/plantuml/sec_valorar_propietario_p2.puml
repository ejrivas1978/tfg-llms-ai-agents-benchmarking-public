@startuml sec_valorar_propietario_p2

' ============================================================
' Estilo claro estandar — fondo blanco, fuente y lineas negras,
' rellenos pastel suaves. NO MODO OSCURO.
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam defaultFontName "Helvetica"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 6
skinparam ArrowColor #000000
skinparam ArrowFontColor #000000

skinparam noteBackgroundColor #FFF9CC
skinparam noteBorderColor #B5852E
skinparam noteFontColor #000000

skinparam titleFontColor #1F4E79
skinparam titleFontSize 14
skinparam titleFontStyle bold

skinparam dividerBackgroundColor #F2F2F2
skinparam dividerFontColor #000000

skinparam sequence {
  ActorBackgroundColor #DAE8FC
  ActorBorderColor #000000
  ActorFontColor #000000
  ParticipantBackgroundColor #FFF2CC
  ParticipantBorderColor #000000
  ParticipantFontColor #000000
  LifeLineBorderColor #000000
  LifeLineBackgroundColor #FFFFFF
  ArrowColor #000000
  ArrowFontColor #000000
  GroupBackgroundColor #F2F2F2
  GroupHeaderFontColor #000000
  GroupBorderColor #000000
  ReferenceBackgroundColor #FFF9CC
  ReferenceBorderColor #B5852E
  ReferenceFontColor #000000
  DividerBackgroundColor #F2F2F2
  DividerFontColor #000000
}
skinparam activationBackgroundColor #FFF2CC
skinparam activationBorderColor #000000
skinparam databaseBackgroundColor #E1D5E7
skinparam databaseBorderColor #000000
skinparam databaseFontColor #000000

' ============================================================
' Secuencia: Valoracion por el usuario web propietario — Parte 2/2
' Valorar respuestas (estrellas + drag) y guardar (RF-12, RF-13)
' Viene de sec_valorar_propietario_p1.
' ============================================================

autonumber

actor "Usuario web\n(propietario)" as Usuario
participant "EvalViewModal\n(EvaluationPage)" as UI
participant "evaluacionApi.ts" as API
participant "POST /evaluaciones\n(FastAPI)" as Router
participant "EvaluacionService" as Svc
database "PostgreSQL" as DB

note over Usuario, DB
  ══════════════════════════════════════════
   Viene de sec_valorar_propietario_p1
  ══════════════════════════════════════════
end note

== Valorar respuestas (RF-12, RF-13) ==

loop por cada una de las 4 respuestas LLM
  Usuario -> UI : selecciona estrellas (0-5)
  note right of UI
    0 = rechazo por politica
    de seguridad del modelo
    (no es "sin valorar")
  end note
end

loop por cada LLM (4 texto / 3 imagen)
  Usuario -> UI : arrastra chip LLM_i\ndesde pool a slot N
  UI -> UI : asigna LLM_i al slot N\n(rangoPreferencia = N)
  note right of UI
    Reglas DnD:
    - pool -> slot vacio: asigna.
    - pool -> slot ocupado: el
      ocupante vuelve al pool.
    - slot -> slot: swap.
    - slot -> pool: libera el slot.
    Slot ocupado: chip con fondo crema
    del color de marca del LLM (10%).
  end note
end

UI -> UI : rankingCompleto = todos los slots llenos\ntodosConRating = todas las puntuaciones rellenas
note right of UI
  Guardar permanece DESHABILITADO
  hasta rankingCompleto && todosConRating.
  Cuando se cumplen, el boton se habilita
  y parpadea (animate-pulse-strong).
  Indicadores * y v en "Puntuacion"
  y en "Ranking de preferencia".
  YA NO existe ConfirmModal de orden
  porque el drag es obligatorio.
end note

Usuario -> UI : pulsa "Guardar evaluacion"\n(boton habilitado y parpadeando)

== Guardar valoraciones (transaccion por respuesta) ==

loop por cada respuesta valorada
  UI -> API : crearEvaluacion({ response_id, nickname,\nrating, rango_preferencia })
  note right of UI
    rango_preferencia = numero
    del slot al que se arrastro
    el chip (1 = mejor, N = peor).
  end note
  activate API
  API -> Router : POST /api/v1/evaluaciones
  activate Router
  Router -> Svc : crear(...)
  activate Svc
  Svc -> DB : SELECT respuesta\nJOIN benchmark_evaluacion
  DB --> Svc : respuesta + benchmark
  Svc -> Svc : verifica\nrespuesta.benchmark.nickname == nickname
  note right of Svc
    Guard de propietario.
    Para el usuario web propietario
    siempre se cumple por construccion.
  end note
  Svc -> DB : INSERT user_evaluations\n(response_id, nickname,\nrating, rango_preferencia)
  DB --> Svc : id generado
  Svc --> Router : RespuestaEvaluacion
  deactivate Svc
  Router --> API : 201
  deactivate Router
  API --> UI : ok
  deactivate API
end

UI -> UI : modal cierra\nhistorialStore.marcarEvaluada(id)
UI --> Usuario : toast "Evaluacion guardada"

note over DB
  La constraint UNIQUE en
  user_evaluations.response_id
  impide insertar dos valoraciones
  para la misma respuesta LLM
  (relacion 1:1).
end note

@enduml
